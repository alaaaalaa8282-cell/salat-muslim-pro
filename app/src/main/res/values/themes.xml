<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.NoorApp" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/surface_dark</item>
        <item name="android:windowBackground">@color/background_dark</item>
    </style>

    <style name="Theme.NoorApp.FullScreen" parent="Theme.NoorApp">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowShowWhenLocked">true</item>
        <item name="android:windowTurnScreenOn">true</item>
    </style>
</resources>
