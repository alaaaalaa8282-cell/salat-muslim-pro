<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AlaApp" parent="android:Theme.Material.NoTitleBar">
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
    </style>
    <style name="Theme.AlaApp.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bg_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.AlaApp</item>
    </style>
</resources>
